{
  "manifest_version": 3,
  "name": "CrawlMind",
  "version": "1.0",
  "description": "AI-powered web scraper with automatic page analysis",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "CrawlMind",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content/analyzer.js"],
    "run_at": "document_idle"
  }]
}
